#version 460
#extension GL_EXT_scalar_block_layout : enable
#extension GL_EXT_buffer_reference : enable

// ------------------------------------------------------------------
// Constants (TEMP — replace with your real values)
// ------------------------------------------------------------------
#define NEIGHBOR_OFFSET_COUNT 256
#define RCDATA_PATH_NUM 64
#define RCDATA_PAD_SIZE 16
#define kCandidateSamples 8

// ------------------------------------------------------------------
// Basic structs
// ------------------------------------------------------------------

struct PackedHitInfo
{
    uint x, y, z, w;
};

struct HitInfo
{
    vec4 misc1;
};

struct TriangleHit
{
    vec3 dummy;
};

struct ShadingData
{
    vec3 posW;
    vec3 N;
    vec3 V;
};

struct PathReservoir
{
    vec4 F;
    vec4 cachedJacobian;

    vec4 rcVertexWi[2];
    vec4 rcVertexIrradiance[2];

    vec4 misc1;
    vec4 misc2;

    HitInfo hitInfo;
};

struct ReconnectionData
{
    HitInfo rcPrevHit;
    vec4 rcPrevWo;
    vec4 pathThroughput;
};

struct PixelReconnectionData
{
    ReconnectionData data[RCDATA_PATH_NUM];
    vec4 padding[RCDATA_PAD_SIZE];
};

struct RestirPathTracerParams
{
    uvec2 frameDim;
    uint seed;
};

// ------------------------------------------------------------------
