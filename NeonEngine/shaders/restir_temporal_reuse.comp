vec3 evalBSDFCosine(const ShadingData sd, const vec3 wi)
{
    vec3 N = normalize(sd.N.xyz);
    vec3 albedo = sd.diffuse.xyz;

    float cosTheta = max(dot(N, wi), 0.0);

    // Lambert BRDF = albedo / PI
    // Cosine term included => (albedo / PI) * cosTheta
    return albedo * cosTheta * (1.0 / 3.14159265);
}


float evalPdfBSDF(const ShadingData sd, const vec3 wi)
{
    vec3 N = normalize(sd.N.xyz);

    float cosTheta = max(dot(N, wi), 0.0);

    // Lambert cosine-weighted hemisphere PDF
    return cosTheta / 3.14159265;
}

// wrk


vec3 computeShiftedIntegrand(
    const ShadingData dstSd,
    const ShadingData srcRcSd,
    const vec3 srcWi,
    const vec3 srcF,
    const vec3 cachedJacobian,
    out float outJacobian
)
{
    // ---------------------------------------
    // Reconstruct geometry term
    // ---------------------------------------
    vec3 dstToRc = srcRcSd.posW.xyz - dstSd.posW.xyz;
    float dist2 = dot(dstToRc, dstToRc);
    vec3 wi = normalize(dstToRc);

    float G = abs(dot(dstSd.N.xyz, wi)) *
              abs(dot(srcRcSd.N.xyz, -wi)) / max(dist2, 1e-6);

    // ---------------------------------------
    // Evaluate BSDF at destination
    // ---------------------------------------



    vec3 f_dst = evalBSDFCosine(dstSd, wi);

    float dstPdf = evalPdfBSDF(dstSd, wi);

    // ---------------------------------------
    // Reconstruct source PDFs
    // ---------------------------------------
    float prevPdf = cachedJacobian.x;
    float srcPdf  = cachedJacobian.y;
    float srcG    = cachedJacobian.z;

    // ---------------------------------------
    // Jacobian (shift correction)
    // ---------------------------------------
    float J = 0.0;
    if (srcPdf > 0.0 && srcG > 0.0)
    {
        J = (dstPdf * G) / (srcPdf * srcG);
    }

    outJacobian = J;

    // ---------------------------------------
    // Final shifted contribution
    // ---------------------------------------
    return srcF * J;
}

//cls
bool mergeInSamplePixel(
    inout PathReservoir dst,
    PathReservoir inReservoir,
    inout uint rng
)
{
    float w = inReservoir.weight;

    dst.M += inReservoir.M;

    if (isnan(w) || w == 0.0)
        return false;

    dst.weight += w;

    // Accept?
    if (nextFloat(rng) * dst.weight <= w)
    {
        dst.pathFlags = inReservoir.pathFlags;
        dst.rcRandomSeed = inReservoir.rcRandomSeed;
        dst.initRandomSeed = inReservoir.initRandomSeed;
        dst.cachedJacobian = inReservoir.cachedJacobian;
        dst.lightPdf = inReservoir.lightPdf;

        dst.rcVertexWi[0] = inReservoir.rcVertexWi[0];
        dst.rcVertexWi[1] = inReservoir.rcVertexWi[1];

        dst.hitInfo = inReservoir.hitInfo;

        dst.rcVertexIrradiance[0] = inReservoir.rcVertexIrradiance[0];
        dst.rcVertexIrradiance[1] = inReservoir.rcVertexIrradiance[1];

        dst.rcVertexBSDFLightSamplingIrradiance = inReservoir.rcVertexBSDFLightSamplingIrradiance;
        dst.rcLightPdf = inReservoir.rcLightPdf;

        dst.F = inReservoir.F;
        return true;
    }

    return false;
}

//cls
bool shiftAndMergeReservoir(
    inout PathReservoir dstReservoir,
    PathReservoir srcReservoir,
    ShadingData dstSd,
    ShadingData srcRcSd,
    inout uint rng,
    float misWeight,
    bool useResamplingMIS
)
{
    if (srcReservoir.M == 0.0)
        return false;

    // ---------------------------------------
    // Compute shifted integrand
    // ---------------------------------------
    float J;
    vec3 shiftedF = computeShiftedIntegrand(
        dstSd,
        srcRcSd,
        srcReservoir.rcVertexWi[0].xyz,
        srcReservoir.F.xyz,
        srcReservoir.cachedJacobian.xyz,
        J
    );

    if (all(lessThanEqual(shiftedF, vec3(0.0))) || J <= 0.0)
        return false;

    // ---------------------------------------
    // Merge
    // ---------------------------------------
    if (useResamplingMIS)
    {
        return PathReservoir_merge(
            dstReservoir,
            shiftedF,
            J,
            srcReservoir,
            rng,
            misWeight,
            false
        );
    }
    else
    {
        return mergeInSamplePixel(
            dstReservoir,
            srcReservoir,
            rng
        );
    }
}

//cls
bool mergeWithResamplingMIS(
    inout PathReservoir dst,
    vec4 in_F,
    float in_Jacobian,
    PathReservoir inReservoir,
    inout uint rng,
    float misWeight,
    bool forceAdd
)
{
    float w = PathReservoir_toScalar(in_F.xyz) * in_Jacobian * inReservoir.weight * misWeight;

    dst.M += inReservoir.M;

    if (isnan(w) || w == 0.0)
        return false;

    dst.weight += w;

    // Accept?
    if (forceAdd || nextFloat(rng) * dst.weight <= w)
    {
        dst.pathFlags = inReservoir.pathFlags;
        dst.rcRandomSeed = inReservoir.rcRandomSeed;
        dst.initRandomSeed = inReservoir.initRandomSeed;
        dst.cachedJacobian = inReservoir.cachedJacobian;
        dst.lightPdf = inReservoir.lightPdf;

        dst.rcVertexWi[0] = inReservoir.rcVertexWi[0];
        dst.rcVertexWi[1] = inReservoir.rcVertexWi[1];

        dst.hitInfo = inReservoir.hitInfo;

        dst.rcVertexIrradiance[0] = inReservoir.rcVertexIrradiance[0];
        dst.rcVertexIrradiance[1] = inReservoir.rcVertexIrradiance[1];

        dst.rcVertexBSDFLightSamplingIrradiance = inReservoir.rcVertexBSDFLightSamplingIrradiance;
        dst.rcLightPdf = inReservoir.rcLightPdf;

        dst.F = in_F;
        return true;
    }

    return false;
}



