//cls
uint initRNG(uvec2 pixel, uint frame, uint extra)
{
    uint seed = pixel.x * 1973u + pixel.y * 9277u + frame * 26699u + extra * 104729u;
    seed ^= (seed << 13);
    seed ^= (seed >> 17);
    seed ^= (seed << 5);
    return seed;
}

//cls
uint nextUInt(inout uint state)
{
    state ^= state << 13;
    state ^= state >> 17;
    state ^= state << 5;
    return state;
}

//cls
float nextFloat(inout uint state)
{
    return float(nextUInt(state)) * (1.0 / 4294967296.0); // 1 / 2^32
}

//cls
vec2 nextVec2(inout uint state)
{
    return vec2(nextFloat(state), nextFloat(state));
}



//cls 
Ray computeRayPinhole(uvec2 pixel, uvec2 frameDim)
{
    Ray ray;

    // Compute the normalized ray direction assuming a pinhole camera.
    ray.origin = gPathRetracePass.posW;
    vec2 uv = (vec2(pixel) + 0.5) / vec2(frameDim);
    vec2 ndc = uv * 2.0 - 1.0;

    ray.dir = normalize(vec3(ndc, 1.0));

    float invCos = 1.f / dot(normalize(gPathRetracePass.cameraW), ray.dir);
    ray.tMin = gPathRetracePass.nearZ * invCos;
    ray.tMax = gPathRetracePass.farZ * invCos;

    return ray;
}

//cls
bool isValidHitInfo(HitInfo packed)
{
    return packed.misc1.x != 0.0;
}

//cls
ShadingData getPixelShadingData(ivec2 pixel, out HitInfo PrimaryHitPacked)
{
    ShadingData sd;

    Ray ray = computeRayPinhole(pixel,gPathRetracePass.params.frameDim);

    uint idx = pixel.y *gPathRetracePass.params.frameDim.x + pixel.x;
    PrimaryHitPacked = vBuff.h[idx];

    if (isValidHitInfo(PrimaryHitPacked))
    {
        
        ShadingData sd;
        sd.posW = vec4(0.0);
        sd.N = vec4(0.0);
        sd.V = vec4(0.0);
        sd.faceN = vec4(0.0);
        sd.diffuse = vec4(0.0);
        sd.materialID = 0u;
        sd.flags = 0u;
        sd.NdotV = 0.0;
        sd.pad = 0.0;
        bool valid = loadShadingData(uvec2(pixel), gPathRetracePass.params.frameDim, sd, PrimaryHitPacked);
    }

    return sd;
}


//cls
ShadingData getPixelTemporalShadingData(ivec2 pixel, out HitInfo PrimaryHitPacked)
{
    ShadingData sd;

    Ray ray = computeRayPinhole(pixel,gPathRetracePass.params.frameDim);

    uint idx = pixel.y * gPathRetracePass.params.frameDim.x + pixel.x;
    PrimaryHitPacked = tempVBuff.tH[idx];

    if (isValidHitInfo(PrimaryHitPacked))
    {
        
        ShadingData sd;
        sd.posW = vec4(0.0);
        sd.N = vec4(0.0);
        sd.V = vec4(0.0);
        sd.faceN = vec4(0.0);
        sd.diffuse = vec4(0.0);
        sd.materialID = 0u;
        sd.flags = 0u;
        sd.NdotV = 0.0;
        sd.pad = 0.0;
        bool valid = loadShadingData(uvec2(pixel), gPathRetracePass.params.frameDim, sd, PrimaryHitPacked);
    }

    return sd;

}

//cls
void PathReservoir_copyMeta(inout PathReservoir dst, PathReservoir src)
{
    dst.F = src.F;
    dst.cachedJacobian = src.cachedJacobian;

    dst.rcVertexWi[0] = src.rcVertexWi[0];
    dst.rcVertexWi[1] = src.rcVertexWi[1];

    dst.rcVertexIrradiance[0] = src.rcVertexIrradiance[0];
    dst.rcVertexIrradiance[1] = src.rcVertexIrradiance[1];

    dst.hitInfo = src.hitInfo;

    dst.rcVertexBSDFLightSamplingIrradiance = src.rcVertexBSDFLightSamplingIrradiance;

    dst.M = src.M;
    dst.weight = src.weight;

    dst.pathFlags = src.pathFlags;
    dst.rcRandomSeed = src.rcRandomSeed;

    dst.lightPdf = src.lightPdf;
    dst.initRandomSeed = src.initRandomSeed;
    dst.rcLightPdf = src.rcLightPdf;
}



//cls

bool PathReservoir_merge(
    inout PathReservoir dst,
    vec3 in_F,
    float in_Jacobian,
    PathReservoir src,
    inout uint rng,
    float misWeight,
    bool forceAdd
)
{
    float w = PathReservoir_toScalar(in_F) *
              in_Jacobian *
              src.M *
              src.weight *
              misWeight;

    // Always accumulate M first (matches reference)
    dst.M += src.M;

    // Reject invalid weights
    if (isnan(w) || w == 0.0)
        return false;

    // Accumulate weighti
    dst.weight += w;

    // Reservoir acceptance test
    if (forceAdd || nextFloat(rng) * dst.weight <= w)
    {
        dst.pathFlags = src.pathFlags;
        dst.rcRandomSeed = src.rcRandomSeed;
        dst.initRandomSeed = src.initRandomSeed;
        dst.cachedJacobian = src.cachedJacobian;
        dst.lightPdf = src.lightPdf;

        // RC vertex data (BPR always enabled)
        dst.rcVertexWi[0] = src.rcVertexWi[0];
        dst.rcVertexWi[1] = src.rcVertexWi[1];

        dst.hitInfo = src.hitInfo;

        dst.rcVertexIrradiance[0] = src.rcVertexIrradiance[0];
        dst.rcVertexIrradiance[1] = src.rcVertexIrradiance[1];

        dst.rcVertexBSDFLightSamplingIrradiance =
            src.rcVertexBSDFLightSamplingIrradiance;

        dst.rcLightPdf = src.rcLightPdf;

        dst.F = vec4(in_F,0);

        return true;
    }

    return false;
}

