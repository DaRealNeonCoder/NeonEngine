//cls
bool isValidScreenRegion(ivec2 pixel)
{
    return all(greaterThanEqual(pixel, ivec2(0))) &&
           all(lessThan(pixel,gPathRetracePass.params.frameDim));
}

//cls
uint getOffset(uvec2 p)
{
    return p.y * uint(gPathRetracePass.params.frameDim.x) + p.x;
}


//cls
void ReSTIR(uvec2 pixel)
{
    uint rng = initRNG(
    pixel,
    gPathRetracePass.params.seed,
    uint(gPathRetracePass.gSpatialRoundId)
    );

    uint centralOffset = getOffset(pixel);


    PathReservoir dstReservoir = outputReservoirs[centralOffset]; // redundant but alas.
    PathReservoir centralReservoir = dstReservoir;

    float currentM = dstReservoir.M;
    vec3 initialColor = dstReservoir.F.xyz * dstReservoir.weight;


    // -----------------------------------------
    // Talbot init / prepare merging
    // -----------------------------------------
    bool Talbot = true;

    if (Talbot)
        PathReservoir_init(dstReservoir);
    else
        PathReservoir_prepareMerging(dstReservoir);

    // -----------------------------------------
    // Load shading data
    // -----------------------------------------
    HitInfo centralPacked;
    ShadingData centralSd = getPixelShadingData(ivec2(pixel), centralPacked);

    if (!isValidHitInfo(centralPacked))
        return;

    // -----------------------------------------
    // Reproject
    // -----------------------------------------
    vec2 motion = texelFetch(motionVectors, ivec2(pixel), 0).xy;

    ivec2 prevPixel = ivec2(pixel);

    if (gPathRetracePass.gEnableTemporalReprojection == 1)
    {
        vec2 jitter = nextVec2(rng);
        prevPixel = ivec2(vec2(pixel) + motion * vec2(gPathRetracePass.params.frameDim) + jitter);
    }

    if (!isValidScreenRegion(prevPixel))
        return;

    HitInfo temporalPacked;
    ShadingData temporalSd = getPixelTemporalShadingData(prevPixel, temporalPacked);

    if (!isValidHitInfo(temporalPacked))
        return;

    uint prevOffset = getOffset(uvec2(prevPixel));
    PathReservoir temporalReservoir = temporalReservoirs[prevOffset];

    temporalReservoir.M = min(
        gPathRetracePass.gTemporalHistoryLength * currentM,
        temporalReservoir.M
    );

    // -----------------------------------------
    // Reconnection data (Hybrid shift)
    // -----------------------------------------
    ReconnectionData rcData;
    ReconnectionData dummyRcData;

    // -----------------------------------------
    // TEMPORAL REUSE (TOGGLEABLE MIS)
    // -----------------------------------------

    //talbot multiple importance sampling is fine, RMIS branch is unconfirmed.

    if (gPathRetracePass.useTalbotMIS == 1)
    {
        float dstJacobian;

        // =====================================
        // TALBOT RMIS
        // =====================================
        for (int i = -1; i <= 0; i++)
        {
            float p_sum = 0.0;
            float p_self = 0.0;

            PathReservoir tempDst = dstReservoir;

            bool possible = false;

            // ---------------------------------
            // Candidate selection
            // ---------------------------------
            if (i == -1)
            {
                dstJacobian = 1.0;
                tempDst = centralReservoir;
                possible = tempDst.weight > 0.0;
            }
            else
            {
                //preform hybrid shift

                rcData = reconnectionDataBuffer[centralOffset].data[1];

                possible = shiftAndMergeReservoir(
                    tempDst,
                    temporalReservoir,
                    centralSd,
                    temporalSd,
                    rng,
                    1.0,
                    true // hypothetical selection
                );
            }

            if (!possible) continue;

            // ---------------------------------
            // MIS weight computation
            // ---------------------------------
            for (int j = -1; j <= 0; j++)
            {
                if (j == -1)
                {
                    float cur_p = PathReservoir_toScalar(tempDst.F.xyz) * currentM;
                    p_sum += cur_p;

                    if (i == -1) p_self = cur_p;
                }
                else
                {
                    if (i == j)
                    {
                        float val = PathReservoir_toScalar(temporalReservoir.F.xyz) / dstJacobian
                                    * temporalReservoir.M;

                        p_self = val;
                        p_sum += val;
                        continue;
                    }
                    //hybrid, reference gave options
                    rcData = reconnectionDataBuffer[centralOffset].data[0];

                    float J;
                    vec3 shiftedF = computeShiftedIntegrand(
                        centralSd,
                        temporalSd,
                        temporalReservoir.rcVertexWi[0].xyz,
                        temporalReservoir.F.xyz,
                        temporalReservoir.cachedJacobian.xyz,
                        J
                    );

                    float p = PathReservoir_toScalar(shiftedF) * J;
                    p_sum += p * temporalReservoir.M;
                }
            }

            float misWeight = (p_sum > 0.0) ? (p_self / p_sum) : 0.0;

            PathReservoir neighbor = (i == -1) ? tempDst : temporalReservoir;

            PathReservoir_merge(
                dstReservoir,
                tempDst.F.xyz,
                dstJacobian,
                neighbor,
                rng,
                misWeight,
                false
            );
        }

        if (dstReservoir.weight > 0.0)
        {
            PathReservoir_finalizeGRIS(dstReservoir);
        }
    }
    else
    {
        // =====================================
        // CONSTANT RMIS
        // =====================================
        float dstJacobian = 1.0;
        bool selected = false;

        // basic temporal merge
        selected = shiftAndMergeReservoir(
            dstReservoir,
            temporalReservoir,
            centralSd,
            temporalSd,
            rng,
            1.0,
            false
        );

        bool chooseCurrent = !selected;

        // ---------------------------------
        // MIS weight
        // ---------------------------------
        if (dstReservoir.weight > 0.0)
        {
            if (chooseCurrent)
            {
                float count = currentM;

                float J;
                vec3 shiftedF = computeShiftedIntegrand(
                        centralSd,
                        temporalSd,
                        temporalReservoir.rcVertexWi[0].xyz,
                        temporalReservoir.F.xyz,
                        temporalReservoir.cachedJacobian.xyz,
                        J
                    );


                float approxPdf = PathReservoir_toScalar(shiftedF) * J;

                if (approxPdf > 0.0)
                    count += temporalReservoir.M;

                float misWeight = 1.0 / max(1.0, count);

                dstReservoir.weight *= dstReservoir.M * misWeight;
            }
            else
            {
                float sum_pdf = PathReservoir_toScalar(temporalReservoir.F.xyz) / dstJacobian;

                float misWeight =
                    (PathReservoir_toScalar(temporalReservoir.F.xyz) / dstJacobian) /
                    (sum_pdf * temporalReservoir.M +
                     PathReservoir_toScalar(dstReservoir.F.xyz) * currentM);

                dstReservoir.weight *= dstReservoir.M * misWeight;
            }
        }

        finalizeRIS(dstReservoir);
    }

    // -----------------------------------------
    // Safety
    // -----------------------------------------
    if (isnan(dstReservoir.weight))
        dstReservoir.weight = 0.0;

    outputReservoirs[centralOffset] = dstReservoir;

    // -----------------------------------------
    // Output color
    // -----------------------------------------
    vec3 color = dstReservoir.F.xyz * dstReservoir.weight;

    if (gPathRetracePass.gIsLastRound == 1)
    {
        if (gPathRetracePass.useDirectLighting == 1)
        {
            color += imageLoad(directLighting, ivec2(pixel)).rgb;
        }

        vec4 prev = imageLoad(outputColor, ivec2(pixel));
        imageStore(outputColor, ivec2(pixel),
            prev + vec4(color, 1.0));
    }
}

// --------------------------------------------------

void main()
{
return;
    uvec2 pixel = gl_GlobalInvocationID.xy;

    if (any(greaterThanEqual(pixel, uvec2(gPathRetracePass.params.frameDim))))
        return;

    ReSTIR(pixel);
}