//RAND
//cls
uint initRNG(uvec2 pixel, uint frame, uint extra)
{
    uint seed = pixel.x * 1973u + pixel.y * 9277u + frame * 26699u + extra * 104729u;
    seed ^= (seed << 13);
    seed ^= (seed >> 17);
    seed ^= (seed << 5);
    return seed;
}

//cls
uint nextUInt(inout uint state)
{
    state ^= state << 13;
    state ^= state >> 17;
    state ^= state << 5;
    return state;
}

//cls
float nextFloat(inout uint state)
{
    return float(nextUInt(state)) * (1.0 / 4294967296.0); // 1 / 2^32
}

//cls
vec2 nextVec2(inout uint state)
{
    return vec2(nextFloat(state), nextFloat(state));
}
// ------------------------------------------------------------------
// Helpers
// ------------------------------------------------------------------
//cls
bool isValidScreenRegion(ivec2 pixel)
{
    return all(greaterThanEqual(pixel, ivec2(0))) &&
           all(lessThan(pixel, ivec2(gPathRetracePass.params.frameDim)));
}
//cls 
Ray computeRayPinhole(uvec2 pixel, uvec2 frameDim)
{
    Ray ray;

    // Compute the normalized ray direction assuming a pinhole camera.
    ray.origin = gPathRetracePass.posW;
    vec2 uv = (vec2(pixel) + 0.5) / vec2(frameDim);
    vec2 ndc = uv * 2.0 - 1.0;

    ray.dir = normalize(vec3(ndc, 1.0));

    float invCos = 1.f / dot(normalize(gPathRetracePass.cameraW), ray.dir);
    ray.tMin = gPathRetracePass.nearZ * invCos;
    ray.tMax = gPathRetracePass.farZ * invCos;

    return ray;
}


// Dummy compute
vec3 computeShiftedIntegrand_(
    RestirPathTracerParams params,
    inout float dstJacobian,
    HitInfo dstPrimaryHitPacked,
    ShadingData dstPrimarySd,
    ShadingData srcPrimarySd,
    inout PathReservoir tempReservoir,
    ReconnectionData rcData,
    bool evalVisibility,
    bool usePrev,
    bool temporalUpdateForDynamicScene
)
{
    dstJacobian = 1.0;
    tempReservoir.cachedJacobian[0] = 1.0;
    tempReservoir.cachedJacobian[1] = 1.0;
    return vec3(1.0);
}

float PathReservoir_toScalar(vec3 F)
{
    return dot(F, vec3(0.299, 0.587, 0.114));
}

// ------------------------------------------------------------------
// Integrand wrapper
// ------------------------------------------------------------------
vec3 computeShiftedIntegrandExtraOutput(
    RestirPathTracerParams params,
    inout float dstJacobian,
    inout float output2,
    HitInfo dstPrimaryHitPacked,
    ShadingData dstPrimarySd,
    ShadingData srcPrimarySd,
    PathReservoir srcReservoir,
    ReconnectionData rcData,
    bool evalVisibility
)
{
    PathReservoir tempReservoir = srcReservoir;

    vec3 res = computeShiftedIntegrand_(
        params,
        dstJacobian,
        dstPrimaryHitPacked,
        dstPrimarySd,
        srcPrimarySd,
        tempReservoir,
        rcData,
        evalVisibility,
        false,
        false
    );

    dstJacobian = tempReservoir.cachedJacobian[0];
    output2     = tempReservoir.cachedJacobian[1];

    return res;
}

