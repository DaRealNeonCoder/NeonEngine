ivec2 getPathReuseNextNeighborPixel(ivec4 NRookQuery, ivec2 pixel, int i)
{
    return pixel + ivec2((i % 4) - 2, (i / 4) - 2);
}



//no idea
vec3 perp_stark(vec3 n)
{
    return normalize(abs(n.z) < 0.999 ? cross(n, vec3(0,0,1)) : cross(n, vec3(0,1,0)));
}
//cls
vec3 getPrimaryRayDir(uvec2 pixel, uvec2 frameDim)
{
    vec2 uv  = (vec2(pixel) + 0.5) / vec2(frameDim);
    vec2 ndc = uv * 2.0 - 1.0;

    // Simple pinhole (matches your computeRayPinhole)
    vec3 dir = normalize(vec3(ndc, 1.0));

    return dir;
}

//cls
bool loadShadingData(
    uvec2 pixel,
    uvec2 frameDim,
    out ShadingData sd,
    out HitInfo hit
)
{
    sd.posW = vec4(0.0);
    sd.N = vec4(0.0);
    sd.V = vec4(0.0);
    sd.faceN = vec4(0.0);
    sd.diffuse = vec4(0.0);
    sd.materialID = 0u;
    sd.flags = 0u;
    sd.NdotV = 0.0;
    sd.pad = 0.0;

    vec3 rayDir = getPrimaryRayDir(pixel, frameDim);

    // ------------------------------------------------------------------
    // GBuffer fetch
    // ------------------------------------------------------------------

    vec4 worldPos = texelFetch(gWorldPosition, ivec2(pixel), 0);

    if (worldPos.w == 0.0)
        return false;

    vec3 normal = normalize(texelFetch(gWorldShadingNormal, ivec2(pixel), 0).xyz);
    vec3 faceNormal = normalize(texelFetch(gWorldFaceNormal, ivec2(pixel), 0).xyz);

    uint materialID = uint(worldPos.w);

    // ------------------------------------------------------------------
    // Material fetch
    // ------------------------------------------------------------------

    Material mat = materials[materialID];

    // ------------------------------------------------------------------
    // Fill shading data
    // ------------------------------------------------------------------

    sd.posW   = vec4(worldPos.xyz, 1.0);
    sd.N      = vec4(normal, 0.0);
    sd.faceN  = vec4(faceNormal, 0.0);
    sd.V      = vec4(normalize(-rayDir), 0.0);

    sd.diffuse = vec4(mat.diffuseOpacity.xyz, 0.0);

    sd.materialID = materialID;
    sd.flags      = 0;

    sd.NdotV = max(dot(normal, -rayDir), 0.0);

    // ------------------------------------------------------------------
    // VBuffer hit (optional, but you already have it)
    // ------------------------------------------------------------------

    uint idx = pixel.y * frameDim.x + pixel.x;
    hit = vBuff.h[idx];

    return true;
}

//cls
bool isValidGeometry(ShadingData a, ShadingData b)
{
    if (gPathRetracePass.gFeatureBasedRejection == 0) return true;

    vec3 camPos = vec3(0.0);

    float d0 = distance(camPos, a.posW.xyz);
    float d1 = distance(camPos, b.posW.xyz);

    return dot(a.N, b.N) >= 0.5 &&
           abs(d0 - d1) < 0.1 * d0;
}


//cls
ShadingData getPixelShadingData(ivec2 pixel, out HitInfo PrimaryHitPacked)
{
    ShadingData sd;

    Ray ray = computeRayPinhole(pixel,gPathRetracePass.params.frameDim);

    uint idx = pixel.y *gPathRetracePass.params.frameDim.x + pixel.x;
    PrimaryHitPacked = vBuff.h[idx];

    if (isValidHitInfo(PrimaryHitPacked))
    {
        
        ShadingData sd;
        sd.posW = vec4(0.0);
        sd.N = vec4(0.0);
        sd.V = vec4(0.0);
        sd.faceN = vec4(0.0);
        sd.diffuse = vec4(0.0);
        sd.materialID = 0u;
        sd.flags = 0u;
        sd.NdotV = 0.0;
        sd.pad = 0.0;
        bool valid = loadShadingData(uvec2(pixel), gPathRetracePass.params.frameDim, sd, PrimaryHitPacked);
    }

    return sd;
}
void PathReservoir_init(inout PathReservoir r)
{
    r.F = vec4(0.0);
    r.cachedJacobian = vec4(0.0);

    r.rcVertexWi[0] = vec4(0.0);
    r.rcVertexWi[1] = vec4(0.0);

    r.rcVertexIrradiance[0] = vec4(0.0);
    r.rcVertexIrradiance[1] = vec4(0.0);

    r.hitInfo.misc1.x = 0; // bary x
    r.hitInfo.misc1.y = 0; // bary y

    r.hitInfo.misc1.z = -1; // set Instance vert to invalid (the ref used the instance ID instead, Id imagine this is fine too :D )

    r.rcVertexBSDFLightSamplingIrradiance = vec4(0.0);

    r.M = 0.0;
    r.weight = 0.0;

    r.pathFlags = 0u;
    r.rcRandomSeed = 0u;

    r.lightPdf = 0.0;
    r.initRandomSeed = 0u;
    r.rcLightPdf = 0.0;
}



//cls
uint getReservoirOffset(uvec2 pixel)
{
    return pixel.y * gPathRetracePass.params.frameDim.x + pixel.x;
}
//cls
int getNeighborCount()
{
    return gPathRetracePass.gNeighborCount;
}
//cls
void BPRComputeMISWeights(ivec2 pixel)
{
    // ------------------------------------------------------------
    // NRooks / block setup (ver2 equivalent)
    // ------------------------------------------------------------
        int blockShiftOffset;
    blockShiftOffset = 16;

    ivec2 block = (pixel - blockShiftOffset + 16) / 16;

    uint seed = gPathRetracePass.params.seed + uint(gPathRetracePass.gSpatialRoundId);

    uint sg = initRNG(uvec2(block), seed, 1337u);



    // replaces TinyUniformSampleGenerator + sampleNext1D

    float patternSample = nextFloat(sg);
    uint patternIndex = min(255u, uint(patternSample * 256.0));

    ivec2 pixelInBlock = (pixel - blockShiftOffset + 16) % 16;
    int pixelInBlockId = pixelInBlock.y * 16 + pixelInBlock.x;

    int byteAddress = pixelInBlockId / 2;

    uint word = nRooksPattern[
        (patternIndex * 256u + 128u + 4u * uint(byteAddress / 4)) / 4u
    ];

    int groupId =
        int((word >> (8 * (byteAddress % 4)))
              >> (4 * (pixelInBlockId % 2))) & 0xF;

    ivec4 NRookQuery = ivec4(pixelInBlock, groupId, int(patternIndex));

    // ------------------------------------------------------------
    // Central reservoir
    // ------------------------------------------------------------
    uint centralOffset = getReservoirOffset(pixel);
    PathReservoir centralReservoir = outputReservoirs[centralOffset];

    HitInfo centralHitPacked;
    ShadingData centralSd = getPixelShadingData(pixel, centralHitPacked);

    //should be fine.
    if (!isValidHitInfo(centralHitPacked))
    {
        return;
    }

    ReconnectionData dummyRcData;
    //dummyRcData.init;
    // ------------------------------------------------------------
    // MIS accumulation
    // ------------------------------------------------------------
    float p_sum = 0.0;
    float p_self = 0.0;

    float p_sum_NEE = 0.0;
    float p_self_NEE = 0.0;

    int neighborCount = getNeighborCount();

    for (int j = 0; j < neighborCount; ++j)
    {
        if (j == pixelInBlock.x)
        {
            float p = PathReservoir_toScalar(centralReservoir.F.xyz) > 0.0 ? 1.0 : 0.0;
            float p_NEE = PathReservoir_toScalar(centralReservoir.rcVertexIrradiance[1].xyz) > 0.0 ? 1.0 : 0.0;

            p_self = p;
            p_self_NEE = p_NEE;

            p_sum += p;
            p_sum_NEE += p_NEE;
        }
        else
        {
            ivec2 neighborPixel =
                getPathReuseNextNeighborPixel(NRookQuery, pixel, j);

            if (!isValidScreenRegion(neighborPixel))
                continue;

            HitInfo neighborHitPacked;
            ShadingData neighborSd = getPixelShadingData(neighborPixel, neighborHitPacked);

            if (!isValidHitInfo(neighborHitPacked))
                continue;

            float jacobian = 0.0;
            float neeOut = 0.0;

            computeShiftedIntegrandExtraOutput(
                gPathRetracePass.params,
                jacobian,
                neeOut,
                neighborHitPacked,
                neighborSd,
                centralSd,
                centralReservoir,
                dummyRcData,
                true
            );

            float p = jacobian;
            float p_NEE = neeOut;

            p_sum += p;
            p_sum_NEE += p_NEE;
        }
    }

    // ------------------------------------------------------------
    // MIS weights
    // ------------------------------------------------------------
    float misWeight     = (p_sum == 0.0) ? 0.0 : (p_self / p_sum);
    float misWeightNEE  = (p_sum_NEE == 0.0) ? 0.0 : (p_self_NEE / p_sum_NEE);

    misWeightBuffer[centralOffset].rcBSDFMISWeight = misWeight;
    misWeightBuffer[centralOffset].rcNEEMISWeight  = misWeightNEE;

}
// ------------------------------------------------------------------
// Entry
// ------------------------------------------------------------------
void execute(uvec2 pixel)
{
    if (!isValidScreenRegion(ivec2(pixel)))
        return;

    BPRComputeMISWeights(ivec2(pixel));
}

// ------------------------------------------------------------------
// Main
// ------------------------------------------------------------------
layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

void main()
{
    execute(gl_GlobalInvocationID.xy);
}