//cls
bool isValidHitInfo(HitInfo packed)
{
    return packed.misc1.x != 0.0;
}

//cls
bool isValidScreenRegion(ivec2 pixel)
{
    return all(greaterThanEqual(pixel, ivec2(0))) &&
           all(lessThan(pixel, ivec2(gPathRetracePass.params.frameDim)));
}


//this was toggle able in oregano.
//cls
bool isValidGeometry(ShadingData centralSd, ShadingData neighborSd)
{

    float centralDist = length(centralSd.posW);
    float neighborDist = length(neighborSd.posW);

    return dot(centralSd.N, neighborSd.N) >= 0.5 &&
           abs(centralDist - neighborDist) < 0.1 * centralDist;
}




//wrk
vec3 perp_stark(vec3 n)
{
    return normalize(abs(n.z) < 0.999 ? cross(n, vec3(0,0,1)) : cross(n, vec3(0,1,0)));
}
//cls
vec3 getPrimaryRayDir(uvec2 pixel, uvec2 frameDim)
{
    vec2 uv  = (vec2(pixel) + 0.5) / vec2(frameDim);
    vec2 ndc = uv * 2.0 - 1.0;

    // Simple pinhole (matches your computeRayPinhole)
    vec3 dir = normalize(vec3(ndc, 1.0));

    return dir;
}
//cls
bool loadShadingData(
    uvec2 pixel,
    uvec2 frameDim,
    out ShadingData sd,
    out HitInfo hit
)
{
    sd.posW = vec4(0.0);
    sd.N = vec4(0.0);
    sd.V = vec4(0.0);
    sd.faceN = vec4(0.0);
    sd.diffuse = vec4(0.0);
    sd.materialID = 0u;
    sd.flags = 0u;
    sd.NdotV = 0.0;
    sd.pad = 0.0;

    vec3 rayDir = getPrimaryRayDir(pixel, frameDim);

    // ------------------------------------------------------------------
    // GBuffer fetch
    // ------------------------------------------------------------------

    vec4 worldPos = texelFetch(gWorldPosition, ivec2(pixel), 0);

    if (worldPos.w == 0.0)
        return false;

    vec3 normal = normalize(texelFetch(gWorldShadingNormal, ivec2(pixel), 0).xyz);
    vec3 faceNormal = normalize(texelFetch(gWorldFaceNormal, ivec2(pixel), 0).xyz);

    uint materialID = uint(worldPos.w);

    // ------------------------------------------------------------------
    // Material fetch
    // ------------------------------------------------------------------

    Material mat = materials[materialID];

    // ------------------------------------------------------------------
    // Fill shading data
    // ------------------------------------------------------------------

    sd.posW   = vec4(worldPos.xyz, 1.0);
    sd.N      = vec4(normal, 0.0);
    sd.faceN  = vec4(faceNormal, 0.0);
    sd.V      = vec4(normalize(-rayDir), 0.0);

    sd.diffuse = vec4(mat.diffuseOpacity.xyz, 0.0);

    sd.materialID = materialID;
    sd.flags      = 0;

    sd.NdotV = max(dot(normal, -rayDir), 0.0);

    // ------------------------------------------------------------------
    // VBuffer hit (optional, but you already have it)
    // ------------------------------------------------------------------

    uint idx = pixel.y * frameDim.x + pixel.x;
    hit = vBuff.h[idx];

    return true;
}

//cls
ShadingData getPixelShadingData(ivec2 pixel, out HitInfo PrimaryHitPacked)
{
    ShadingData sd;

    Ray ray = computeRayPinhole(pixel,gPathRetracePass.params.frameDim);

    uint idx = pixel.y *gPathRetracePass.params.frameDim.x + pixel.x;
    PrimaryHitPacked = vBuff.h[idx];

    if (isValidHitInfo(PrimaryHitPacked))
    {
        
        ShadingData sd;
        sd.posW = vec4(0.0);
        sd.N = vec4(0.0);
        sd.V = vec4(0.0);
        sd.faceN = vec4(0.0);
        sd.diffuse = vec4(0.0);
        sd.materialID = 0u;
        sd.flags = 0u;
        sd.NdotV = 0.0;
        sd.pad = 0.0;
        bool valid = loadShadingData(uvec2(pixel), gPathRetracePass.params.frameDim, sd, PrimaryHitPacked);
    }

    return sd;
}

//cls
uint getReservoirOffset(ivec2 pixel)
{
    return uint(pixel.y * gPathRetracePass.params.frameDim.x + pixel.x);
}

//cls
float rand(inout uint seed)
{
    seed ^= seed << 13;
    seed ^= seed >> 17;
    seed ^= seed << 5;
    return float(seed) / float(0xffffffffu);
}



// ------------------------------------------------------------
// MERGE

bool PathReservoir_merge(
    inout PathReservoir dst,
    vec3 in_F,
    float in_Jacobian,
    PathReservoir src,
    inout uint rng,
    float misWeight,
    bool forceAdd
)
{
    float w = PathReservoir_toScalar(in_F) *
              in_Jacobian *
              src.M *
              src.weight *
              misWeight;

    // Always accumulate M first (matches reference)
    dst.M += src.M;

    // Reject invalid weights
    if (isnan(w) || w == 0.0)
        return false;

    // Accumulate weighti
    dst.weight += w;

    // Reservoir acceptance test
    if (forceAdd || nextFloat(rng) * dst.weight <= w)
    {
        dst.pathFlags = src.pathFlags;
        dst.rcRandomSeed = src.rcRandomSeed;
        dst.initRandomSeed = src.initRandomSeed;
        dst.cachedJacobian = src.cachedJacobian;
        dst.lightPdf = src.lightPdf;

        // RC vertex data (BPR always enabled)
        dst.rcVertexWi[0] = src.rcVertexWi[0];
        dst.rcVertexWi[1] = src.rcVertexWi[1];

        dst.hitInfo = src.hitInfo;

        dst.rcVertexIrradiance[0] = src.rcVertexIrradiance[0];
        dst.rcVertexIrradiance[1] = src.rcVertexIrradiance[1];

        dst.rcVertexBSDFLightSamplingIrradiance =
            src.rcVertexBSDFLightSamplingIrradiance;

        dst.rcLightPdf = src.rcLightPdf;

        dst.F = vec4(in_F,0);

        return true;
    }

    return false;
}






//cls
bool mergeWithResamplingMIS(
    inout PathReservoir dst,
    vec4 in_F,
    float in_Jacobian,
    PathReservoir inReservoir,
    inout uint rng,
    float misWeight,
    bool forceAdd
)
{
    float w = PathReservoir_toScalar(in_F.xyz) * in_Jacobian * inReservoir.weight * misWeight;

    dst.M += inReservoir.M;

    if (isnan(w) || w == 0.0)
        return false;

    dst.weight += w;

    // Accept?
    if (forceAdd || nextFloat(rng) * dst.weight <= w)
    {
        dst.pathFlags = inReservoir.pathFlags;
        dst.rcRandomSeed = inReservoir.rcRandomSeed;
        dst.initRandomSeed = inReservoir.initRandomSeed;
        dst.cachedJacobian = inReservoir.cachedJacobian;
        dst.lightPdf = inReservoir.lightPdf;

        dst.rcVertexWi[0] = inReservoir.rcVertexWi[0];
        dst.rcVertexWi[1] = inReservoir.rcVertexWi[1];

        dst.hitInfo = inReservoir.hitInfo;

        dst.rcVertexIrradiance[0] = inReservoir.rcVertexIrradiance[0];
        dst.rcVertexIrradiance[1] = inReservoir.rcVertexIrradiance[1];

        dst.rcVertexBSDFLightSamplingIrradiance = inReservoir.rcVertexBSDFLightSamplingIrradiance;
        dst.rcLightPdf = inReservoir.rcLightPdf;

        dst.F = in_F;
        return true;
    }

    return false;
}
//wrk
