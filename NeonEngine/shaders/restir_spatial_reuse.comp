    bool gIsLastRound;

    vec3 posW;
    vec3 cameraW;
    float nearZ;
    float farZ;

    int restirMISkind;
    int pathSamplingMode;

} gPathRetracePass;


//cls 
Ray computeRayPinhole(uvec2 pixel, uvec2 frameDim)
{
    Ray ray;

    // Compute the normalized ray direction assuming a pinhole camera.
    ray.origin = gPathRetracePass.posW;
    vec2 uv = (vec2(pixel) + 0.5) / vec2(frameDim);
    vec2 ndc = uv * 2.0 - 1.0;

    ray.dir = normalize(vec3(ndc, 1.0));

    float invCos = 1.f / dot(normalize(gPathRetracePass.cameraW), ray.dir);
    ray.tMin = gPathRetracePass.nearZ * invCos;
    ray.tMax = gPathRetracePass.farZ * invCos;

    return ray;
}

float PathReservoir_toScalar(vec3 F)
{
    return dot(F, vec3(0.299, 0.587, 0.114));
}
//cls
void finalizeRIS(inout PathReservoir r)
{
    float p_hat = PathReservoir_toScalar(r.F.xyz);
    if (p_hat == 0.f || r.M == 0.f) r.weight = 0.f;
    else r.weight = r.weight / (p_hat * r.M);
}


void PathReservoir_init(inout PathReservoir r)
{
    r.F = vec4(0.0);
    r.cachedJacobian = vec4(0.0);

    r.rcVertexWi[0] = vec4(0.0);
    r.rcVertexWi[1] = vec4(0.0);

    r.rcVertexIrradiance[0] = vec4(0.0);
    r.rcVertexIrradiance[1] = vec4(0.0);

    r.hitInfo.misc1.x = 0; // bary x
    r.hitInfo.misc1.y = 0; // bary y

    r.hitInfo.misc1.z = -1; // set Instance vert to invalid (the ref used the instance ID instead, Id imagine this is fine too :D )

    r.rcVertexBSDFLightSamplingIrradiance = vec4(0.0);

    r.M = 0.0;
    r.weight = 0.0;

    r.pathFlags = 0u;
    r.rcRandomSeed = 0u;

    r.lightPdf = 0.0;
    r.initRandomSeed = 0u;
    r.rcLightPdf = 0.0;
}
//cls
void PathReservoir_prepareMerging(inout PathReservoir r)
{
    r.weight *= PathReservoir_toScalar(r.F.xyz) * r.M;
}

//cls
void PathReservoir_finalizeGRIS(inout PathReservoir r)
{
    float p_hat = PathReservoir_toScalar(r.F.xyz);
    if (p_hat == 0.0) r.weight = 0.0;
    else r.weight /= p_hat;
}

//cls
float computeWeight(vec3 color, bool binarize)
{
    float weight = PathReservoir_toScalar(color);
    if (binarize && weight > 0.f) weight = 1.f;
    return weight;
}


