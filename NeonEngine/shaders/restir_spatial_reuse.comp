layout(binding = 13) uniform sampler2D directLighting;

// ------------------------------------------------------------
// HELPERS (1:1 translation)

bool isValidPackedHitInfo(PackedHitInfo packed)
{
    return packed.x != 0u;
}

bool isValidScreenRegion(ivec2 pixel)
{
    return all(greaterThanEqual(pixel, ivec2(0))) &&
           all(lessThan(pixel, params.frameDim));
}

bool isValidGeometry(ShadingData centralSd, ShadingData neighborSd)
{
    if (!gFeatureBasedRejection) return true;

    float centralDist = length(centralSd.posW);
    float neighborDist = length(neighborSd.posW);

    return dot(centralSd.N, neighborSd.N) >= 0.5 &&
           abs(centralDist - neighborDist) < 0.1 * centralDist;
}

// ------------------------------------------------------------
// PLACEHOLDER FUNCTIONS (YOU WILL IMPLEMENT)

ShadingData getPixelShadingData(int2 pixel, out PackedHitInfo PrimaryHitPacked)
{
    ShadingData sd = {};
    Ray ray = gScene.camera.computeRayPinhole(pixel, params.frameDim);
    PrimaryHitPacked = vbuffer[pixel];
    if (isValidPackedHitInfo(PrimaryHitPacked))
    {
        HitInfo PrimaryHit; PrimaryHit.unpack(PrimaryHitPacked);

        TriangleHit th = PrimaryHit.getTriangleHit();
        sd = loadShadingData(PrimaryHit, -ray.dir, true);
    }
    return sd;
}

uint getReservoirOffset(const uint2 pixel)
{
    uint2 tileID = pixel >> kScreenTileBits;

    uint stride = kScreenTileDim.x * kScreenTileDim.y;
    uint tileIdx = tileID.y * screenTiles.x + tileID.x;
    uint tileOffset = tileIdx * stride;

    uint tileBits = kScreenTileBits.x + kScreenTileBits.y;
    uint pixelIdx = interleave_16bit(pixel) & ((1 << tileBits) - 1); // TODO: Use interleave_8bit() if kScreenTileBits <= 4.
    return tileOffset + pixelIdx;
}

float sampleNext1D<S : ISampleGenerator>(inout S sg)
{
    // Use upper 24 bits and divide by 2^24 to get a number u in [0,1).
    // In floating-point precision this also ensures that 1.0-u != 0.0.
    uint bits = sg.next();
    return (bits >> 8) * 0x1p-24;
}


void PathReservoir_copyMeta(inout PathReservoir dst, PathReservoir src)
{
    dst.pathFlags      = src.pathFlags;
    dst.rcRandomSeed   = src.rcRandomSeed;
    dst.initRandomSeed = src.initRandomSeed;
    dst.cachedJacobian = src.cachedJacobian;
    dst.lightPdf       = src.lightPdf;

    dst.rcVertexWi[0] = src.rcVertexWi[0];
    dst.rcVertexHit   = src.rcVertexHit;
    dst.rcVertexIrradiance[0] = src.rcVertexIrradiance[0];

#if BPR
    dst.rcVertexWi[1] = src.rcVertexWi[1];
    dst.rcVertexIrradiance[1] = src.rcVertexIrradiance[1];
    dst.rcVertexBSDFLightSamplingIrradiance = src.rcVertexBSDFLightSamplingIrradiance;
    dst.rcLightPdf = src.rcLightPdf;
#endif
}

bool PathReservoir_merge(
    inout PathReservoir dst,
    vec3 in_F,
    float in_Jacobian,
    PathReservoir src,
    inout SampleGenerator sg,
    float misWeight,
    bool forceAdd
)
{
    float w = PathReservoir_toScalar(in_F) *
              in_Jacobian *
              src.M *
              src.weight *
              misWeight;

    dst.M += src.M;

    if (!isfinite(w) || w == 0.0)
        return false;

    dst.weight += w;

    // Accept?
    if (forceAdd || sampleNext1D(sg) * dst.weight <= w)
    {
        PathReservoir_copyMeta(dst, src);
        dst.F = in_F;
        return true;
    }

    return false;
}

bool PathReservoir_mergeInSamplePixel(
    inout PathReservoir dst,
    PathReservoir src,
    inout SampleGenerator sg
)
{
    float w = src.weight;

    dst.M += src.M;

    if (!isfinite(w) || w == 0.0)
        return false;

    dst.weight += w;

    // Accept?
    if (sampleNext1D(sg) * dst.weight <= w)
    {
        PathReservoir_copyMeta(dst, src);
        dst.F = src.F;
        return true;
    }

    return false;
}

float PathReservoir_toScalar(vec3 F)
{
    // luminance
    return dot(F, vec3(0.299, 0.587, 0.114));
}

bool shiftAndMergeReservoir(
    inout PathReservoir dstReservoir,
    PathReservoir srcReservoir,
    const ShadingData dstSd,
    const ShadingData srcRcSd,
    inout SampleGenerator sg,
    float misWeight,
    bool useResamplingMIS
)
{
    if (srcReservoir.M == 0.0)
        return false;

    // ---------------------------------------
    // Compute shifted integrand
    // ---------------------------------------
    float J;
    vec3 shiftedF = computeShiftedIntegrand(
        dstSd,
        srcRcSd,
        srcReservoir.rcVertexWi[0],
        srcReservoir.F,
        srcReservoir.F, // already includes throughput
        srcReservoir.cachedJacobian,
        J
    );

    if (all(lessThanEqual(shiftedF, vec3(0.0))) || J <= 0.0)
        return false;

    // ---------------------------------------
    // Merge
    // ---------------------------------------
    if (useResamplingMIS)
    {
        return dstReservoir.mergeWithResamplingMIS(
            shiftedF,
            J,
            srcReservoir,
            sg,
            misWeight
        );
    }
    else
    {
        return dstReservoir.merge(
            shiftedF,
            J,
            srcReservoir,
            sg,
            misWeight
        );
    }
}

float3 computeShiftedIntegrand(
    const ShadingData dstSd,
    const ShadingData srcRcSd,
    const float3 srcWi,
    const float3 srcF,
    const float3 srcThroughput,
    const float3 cachedJacobian, // (prevPdf, currPdf, G)
    out float outJacobian
)
{
    // ---------------------------------------
    // Reconstruct geometry term
    // ---------------------------------------
    float3 dstToRc = srcRcSd.pos - dstSd.pos;
    float dist2 = dot(dstToRc, dstToRc);
    float3 wi = normalize(dstToRc);

    float G = abs(dot(dstSd.normal, wi)) *
              abs(dot(srcRcSd.normal, -wi)) / max(dist2, 1e-6);

    // ---------------------------------------
    // Evaluate BSDF at destination
    // ---------------------------------------
    float3 f_dst = evalBSDF(dstSd, wi);

    float dstPdf = evalBSDFPdf(dstSd, wi);

    // ---------------------------------------
    // Reconstruct source PDFs
    // ---------------------------------------
    float prevPdf = cachedJacobian.x;
    float srcPdf  = cachedJacobian.y;
    float srcG    = cachedJacobian.z;

    // ---------------------------------------
    // Jacobian (shift correction)
    // ---------------------------------------
    float J = 0.0;
    if (srcPdf > 0.0 && srcG > 0.0)
    {
        J = (dstPdf * G) / (srcPdf * srcG);
    }

    outJacobian = J;

    // ---------------------------------------
    // Final shifted contribution
    // ---------------------------------------
    return srcF * J;
}


bool mergeReservoirWithResamplingMIS(
    inout PathReservoir dst,
    PathReservoir src,
    float3 shiftedF,
    float J,
    float misWeight,
    inout SampleGenerator sg
)
{
    return dst.mergeWithResamplingMIS(
        shiftedF,
        J,
        src,
        sg,
        misWeight,
        false
    );
}

bool mergeReservoirNoResampling(
    inout PathReservoir dst,
    PathReservoir src,
    inout SampleGenerator sg
)
{
    return dst.mergeInSamplePixel(src, sg);
}



