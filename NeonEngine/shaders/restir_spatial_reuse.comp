    PathReuseMISWeight data[];
} misWeightBuffer;

layout(rgba32f, binding = 9) uniform image2D outputNRDDiffuseRadianceHitDist;
layout(rgba32f, binding = 10) uniform image2D outputNRDSpecularRadianceHitDist;
layout(rgba32f, binding = 11) uniform image2D outputNRDResidualRadianceHitDist;

