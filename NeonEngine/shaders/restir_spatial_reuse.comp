//cls
int getNeighborCount()
{
    return gPathRetracePass.gNeighborCount;
}

//cls
ivec2 getNextNeighborPixel(uint startIndex, ivec2 pixel, int i)
{
    uint idx = (startIndex + uint(i)) & kNeighborOffsetMask;
    vec2 offset = texelFetch(neighborOffsets, int(idx), 0).xy;
    return pixel + ivec2(offset * gPathRetracePass.gGatherRadius);
}

void ReSTIR(uvec2 pixel)
{
    uint seed = gPathRetracePass.params.seed + uint(gPathRetracePass.gSpatialRoundId);
    uint rng = initRNG(pixel, 0u, 1337u);

    uint offset = getReservoirOffset(ivec2(pixel));
    PathReservoir dst = outputReservoirs.data[offset];

    HitInfo packed;
    ShadingData central = getPixelShadingData(ivec2(pixel), packed);

    if (!isValidHitInfo(packed)) return;

    // Initialization matches original logic
    if(gPathRetracePass.pathSamplingMode == 1) // talbot, pairwise or pathreuse
    {
        PathReservoir_init(dst);
    }
    else
    {
        PathReservoir_prepareMerging(dst);
    }
    float centralM = max(dst.M, 1.0);
    int count = getNeighborCount();
    uint start = uint(rand(seed) * float(NEIGHBOR_OFFSET_COUNT));
    ReconnectionData dummyRcData;
    // --------------------------------------------------
    // TALBOT RMIS
    // --------------------------------------------------

    vec3 color = vec3(0.0);
    if (gPathRetracePass.restirMISkind == 1) // ReSTIRMISKind::Talbot = 1
    {
        for (int i = -1; i < count; ++i)
        {
            ivec2 neighborPixel = (i == -1)
                ? ivec2(pixel)
                : getNextNeighborPixel(start, ivec2(pixel), i);

            if (!isValidScreenRegion(neighborPixel)) continue;

            uint no = getReservoirOffset(neighborPixel);
            PathReservoir neighborReservoir = outputReservoirs.data[no];

            HitInfo neighborPacked;
            ShadingData neighborSd = getPixelShadingData(neighborPixel, neighborPacked);

            if (!isValidHitInfo(neighborPacked)) continue;
            if (!isValidGeometry(central, neighborSd)) continue;

            float p_sum = 0.0;
            float p_self = 0.0;

            float J = 0.0;
            vec3 shiftedF = neighborReservoir.F.xyz;

            bool possibleToBeSelected = false;

            PathReservoir tempDstReservoir = dst;

            // -----------------------------
            // Candidate evaluation
            // -----------------------------
            if (i == -1)
            {
                float J = 1.0;
                tempDstReservoir = neighborReservoir;
                possibleToBeSelected = (neighborReservoir.weight > 0.0);
            }
            else
            {
                possibleToBeSelected = shiftAndMergeReservoir(
                    tempDstReservoir,
                    neighborReservoir,
                    central,
                    neighborSd,
                    rng,
                    1.0,
                    true
                );
            }

            if (!possibleToBeSelected) continue;

            // -----------------------------
            // MIS normalization loop
            // -----------------------------
            for (int j = -1; j < count; ++j)
            {
                float cur_p = 0.0;

                if (j == -1)
                {
                    // central candidate
                    float f = computeWeight(tempDstReservoir.F.xyz, false);
                    cur_p = f * centralM;

                    p_sum += cur_p;

                    if (i == -1) p_self = cur_p;
                }
                else
                {
                    if (i == j)
                    {
                        // self term for this neighbor
                        float f = computeWeight(neighborReservoir.F.xyz, false);
                        p_self = (f / J) * neighborReservoir.M;
                        p_sum += p_self;
                        continue;
                    }

                    ivec2 tneighborPixel = getNextNeighborPixel(start, ivec2(pixel), j);

                    if (!isValidScreenRegion(tneighborPixel)) continue;

                    uint to = getReservoirOffset(tneighborPixel);
                    PathReservoir tneighborReservoir = outputReservoirs.data[to];

                    HitInfo tPacked;
                    ShadingData tSd = getPixelShadingData(tneighborPixel, tPacked);

                    if (!isValidHitInfo(tPacked)) continue;
                    if (!isValidGeometry(central, tSd)) continue;

                    float tJ;

                    vec3 tIntegrand = computeShiftedIntegrand(
                        central,
                        tSd,
                        tneighborReservoir.rcVertexWi[0].xyz,
                        tneighborReservoir.F.xyz,
                        tneighborReservoir.cachedJacobian.xyz,
                        tJ
                    );


                    float p_ = computeWeight(tIntegrand, false) * tJ;

                    p_sum += p_ * tneighborReservoir.M;
                }
            }

            float misWeight = (p_sum == 0.0) ? 0.0 : (p_self / p_sum);

            mergeReservoirWithResamplingMIS(
                gPathRetracePass.params,
                tempDstReservoir.F.xyz,
                J,
                dst,
                tempDstReservoir,
                neighborReservoir,
                rng,
                true,
                misWeight
            );
        }

        if (dst.weight > 0.0)
        {
            PathReservoir_finalizeGRIS(dst);
        }

        color = (dst.F * dst.weight).xyz;
    }

    // --------------------------------------------------
    // SIMPLE (NON-TALBOT) VERSION (your original)
    // --------------------------------------------------
    else
    {
        for (int i = -1; i < count; ++i)
        {
            ivec2 np = (i == -1)
                ? ivec2(pixel)
                : getNextNeighborPixel(start, ivec2(pixel), i);

            if (!isValidScreenRegion(np)) continue;

            uint no = getReservoirOffset(np);
            PathReservoir src = outputReservoirs.data[no];

            HitInfo npPacked;
            ShadingData nsd = getPixelShadingData(np, npPacked);

            if (!isValidHitInfo(npPacked)) continue;
            if (!isValidGeometry(central, nsd)) continue;

            float J;
            
            vec3 shiftedF = computeShiftedIntegrand(
                central,
                nsd,
                src.rcVertexWi[0].xyz,
                src.F.xyz,
                src.cachedJacobian.xyz,
                J
            );

            if (J > 0.0)
            {
                PathReservoir_merge(dst, shiftedF, J, src, rng, 1.0, false);//wrk
            }
        }
    }

    // --------------------------------------------------
    // FINAL COLOR
    // --------------------------------------------------
    color = (dst.F * dst.weight).xyz;

    if (gPathRetracePass.gIsLastRound)
    {
        vec4 prev = imageLoad(outputColor, ivec2(pixel));
        imageStore(outputColor, ivec2(pixel),
            prev + vec4(color, 1.0));
    }

    temporalReservoirs.data[offset] = dst;
}

