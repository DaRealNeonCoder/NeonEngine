const uint CELL_FLUID = 1u;
const uint CELL_SOLID = 2u;


void atomicAddFloatUAccum(uint idx, float value) {
    uint oldBits = uAccum[idx];
    for (;;) {
        float oldVal = uintBitsToFloat(oldBits);
        float newVal = oldVal + value;
        uint newBits = floatBitsToUint(newVal);
        uint prev = atomicCompSwap(uAccum[idx], oldBits, newBits);
        if (prev == oldBits) return;
        oldBits = prev;
    }
}

