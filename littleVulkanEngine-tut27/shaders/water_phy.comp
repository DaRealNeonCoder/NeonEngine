#version 450
layout(local_size_x = 64) in;

layout(set = 0, binding = 0) readonly buffer InPositions {
    vec4 positions[];
} inBuf;

layout(set = 0, binding = 1) writeonly buffer OutPositions {
    vec4 positions[];
} outBuf;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    // Example processing: reflect across X axis + scale
    vec4 p = inBuf.positions[idx];
    outBuf.positions[idx] = vec4(p.x + 0.01, p.y, p.z, p.w) * 2.0;
}